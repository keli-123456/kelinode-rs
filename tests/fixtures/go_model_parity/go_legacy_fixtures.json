    {
      "name": "route_block",
      "go_source_reference": [
        "kelinode/core/custom.go: block action maps domain rules to block outbound",
        "kelinode/core/outbound.go: buildBlockOutbound uses blackhole protocol"
      ],
      "panel_node": {
        "protocol": "http",
        "listen_ip": "127.0.0.1",
        "server_port": 19113,
        "routes": [
          {
            "id": 1,
            "match": [
              "domain:blocked.example"
            ],
            "action": "block"
          }
        ]
      },
      "users": [
        {
          "id": 113,
          "uuid": "route-user",
          "speed_limit": 0,
          "device_limit": 0
        }
      ],
      "expected": {
        "protocol": "http",
        "transport_network": "tcp",
        "route_targets": [
          "domain:blocked.example"
        ],
        "route_action": "block",
        "decision": "render"
      }
    },
    {
      "name": "custom_outbound",
      "go_source_reference": [
        "kelinode/core/custom.go: route action parses action_value as Xray outbound and adds matching rule",
        "kelinode/core/custom.go: duplicate outbound tags are added only once"
      ],
      "panel_node": {
        "protocol": "http",
        "listen_ip": "127.0.0.1",
        "server_port": 19114,
        "routes": [
          {
            "id": 2,
            "match": [
              "geosite:openai"
            ],
            "action": "route",
            "action_value": "{\"tag\":\"ss-out\",\"protocol\":\"shadowsocks\",\"settings\":{\"servers\":[{\"address\":\"proxy.example.test\",\"port\":8388,\"method\":\"aes-128-gcm\",\"password\":\"route-password\"}]}}"
          }
        ]
      },
      "users": [
        {
          "id": 114,
          "uuid": "custom-route-user",
          "speed_limit": 0,
          "device_limit": 0
        }
      ],
      "expected": {
        "protocol": "http",
        "transport_network": "tcp",
        "route_targets": [
          "geosite:openai"
        ],
        "route_action": "outbound",
        "outbound_protocol": "shadowsocks",
        "decision": "render"
      }
    },
