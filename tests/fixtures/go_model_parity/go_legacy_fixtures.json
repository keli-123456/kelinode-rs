{
  "description": "Go legacy model parity fixtures derived from kelinode core renderer semantics and keli-core/Xray config model. Secrets are synthetic test values.",
  "cases": [
    {
      "name": "trojan_tcp",
      "go_source_reference": [
        "kelinode/core/inbound.go: buildTrojan defaults empty network to tcp",
        "kelinode/core/user.go: buildTrojanUser uses uuid as password and email tag|uuid"
      ],
      "panel_node": {
        "protocol": "trojan",
        "listen_ip": "0.0.0.0",
        "server_port": 19101,
        "network": "tcp",
        "tls": 0
      },
      "users": [
        {
          "id": 101,
          "uuid": "trojan-password",
          "speed_limit": 2048,
          "device_limit": 3
        }
      ],
      "expected": {
        "protocol": "trojan",
        "transport_network": "tcp",
        "security": "none",
        "user_model": "password",
        "decision": "render"
      }
    },
    {
      "name": "trojan_tls",
      "go_source_reference": [
        "kelinode/core/inbound.go: TLS cert_info maps to StreamConfig TLSSettings",
        "keli-core/infra/conf/trojan.go: Trojan server account is password based"
      ],
      "panel_node": {
        "protocol": "trojan",
        "listen_ip": "127.0.0.1",
        "server_port": 19102,
        "network": "tcp",
        "tls": 1,
        "tls_settings": {
          "server_name": "trojan.example.test",
          "cert_mode": "file",
          "cert_file": "/srv/v2node/trojan.cer",
          "key_file": "/srv/v2node/trojan.key",
          "alpn": [
            "http/1.1"
          ]
        }
      },
      "users": [
        {
          "id": 102,
          "uuid": "trojan-tls-password",
          "speed_limit": 0,
          "device_limit": 0
        }
      ],
      "expected": {
        "protocol": "trojan",
        "transport_network": "tcp",
        "security": "tls",
        "tls_server_name": "trojan.example.test",
        "user_model": "password",
        "decision": "render"
      }
    },
    {
      "name": "trojan_ws",
      "go_source_reference": [
        "kelinode/core/inbound.go: buildTrojan unmarshals ws network_settings into WSSettings",
        "keli-core/transport/internet/websocket: mature Xray WebSocket stream semantics"
      ],
      "panel_node": {
        "protocol": "trojan",
        "listen_ip": "127.0.0.1",
        "server_port": 19103,
        "network": "ws",
        "tls": 0,
        "network_settings": {
          "path": "/trojan",
          "headers": {
            "Host": "cdn.example.test"
          }
        }
      },
      "users": [
        {
          "id": 103,
          "uuid": "trojan-ws-password",
          "speed_limit": 0,
          "device_limit": 0
        }
      ],
      "expected": {
        "protocol": "trojan",
        "transport_network": "ws",
        "transport_path": "/trojan",
        "transport_host": "cdn.example.test",
        "security": "none",
        "user_model": "password",
        "decision": "reject",
        "reject_reason_contains": "trojan websocket native relay requires explicit canary gate and soak"
      }
    },
    {
      "name": "trojan_tls_ws",
      "go_source_reference": [
        "kelinode/core/inbound.go: TLS is applied before ws stream settings for Trojan",
        "kelinode/core/inbound.go: ws path and Host are preserved in network_settings"
      ],
      "panel_node": {
        "protocol": "trojan",
        "listen_ip": "127.0.0.1",
        "server_port": 19104,
        "network": "ws",
        "tls": 1,
        "tls_settings": {
          "server_name": "trojan-ws.example.test",
          "cert_mode": "file",
          "cert_file": "/srv/v2node/trojan-ws.cer",
          "key_file": "/srv/v2node/trojan-ws.key",
          "alpn": [
            "http/1.1"
          ],
          "reject_unknown_sni": "1"
        },
        "network_settings": {
          "path": "/trojan-tls",
          "headers": {
            "Host": "edge.example.test"
          }
        }
      },
      "users": [
        {
          "id": 104,
          "uuid": "trojan-tls-ws-password",
          "speed_limit": 0,
          "device_limit": 0
        }
      ],
      "expected": {
        "protocol": "trojan",
        "transport_network": "ws",
        "transport_path": "/trojan-tls",
        "transport_host": "edge.example.test",
        "security": "tls",
        "tls_server_name": "trojan-ws.example.test",
        "user_model": "password",
        "decision": "reject",
        "reject_reason_contains": "trojan tls websocket native relay requires explicit canary gate and soak"
      }
    },
    {
      "name": "vless_tcp_tls_vision",
      "go_source_reference": [
        "kelinode/core/inbound.go: buildVLess passes flow to VLESS users",
        "kelinode/core/inbound.go: TLS cert_info maps to stream TLSSettings"
      ],
      "panel_node": {
        "protocol": "vless",
        "listen_ip": "127.0.0.1",
        "server_port": 19105,
        "network": "tcp",
        "tls": 1,
        "flow": "xtls-rprx-vision",
        "tls_settings": {
          "server_name": "vless-vision.example.test",
          "cert_mode": "file",
          "cert_file": "/srv/v2node/vless-vision.cer",
          "key_file": "/srv/v2node/vless-vision.key",
          "alpn": [
            "h2",
            "http/1.1"
          ]
        }
      },
      "users": [
        {
          "id": 105,
          "uuid": "11111111-1111-1111-1111-111111111111",
          "speed_limit": 0,
          "device_limit": 0
        }
      ],
      "expected": {
        "protocol": "vless",
        "transport_network": "tcp",
        "security": "tls",
        "flow": "xtls-rprx-vision",
        "tls_server_name": "vless-vision.example.test",
        "user_model": "uuid",
        "decision": "render"
      }
    },
    {
      "name": "vless_reality_vision",
      "go_source_reference": [
        "kelinode/core/inbound.go: Reality dest falls back to server_name and appends server_port",
        "kelinode/core/inbound.go: REALITY settings preserve private_key, short_id, xver, and server_names"
      ],
      "panel_node": {
        "protocol": "vless",
        "listen_ip": "127.0.0.1",
        "server_port": 19106,
        "network": "tcp",
        "tls": 2,
        "flow": "xtls-rprx-vision",
        "tls_settings": {
          "server_name": "reality.example.test",
          "dest": "origin.example.test",
          "server_port": "443",
          "private_key": "BwcHBwcHBwcHBwcHBwcHBwcHBwcHBwcHBwcHBwcHBwc",
          "short_id": "6ba85179e30d4fc2",
          "xver": "0"
        }
      },
      "users": [
        {
          "id": 106,
          "uuid": "22222222-2222-2222-2222-222222222222",
          "speed_limit": 0,
          "device_limit": 0
        }
      ],
      "expected": {
        "protocol": "vless",
        "transport_network": "tcp",
        "security": "reality",
        "flow": "xtls-rprx-vision",
        "tls_server_name": "reality.example.test",
        "reality_dest": "origin.example.test:443",
        "user_model": "uuid",
        "decision": "render"
      }
    },
