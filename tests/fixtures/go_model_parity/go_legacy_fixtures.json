    {
      "name": "unsupported_tcp_header_field",
      "go_source_reference": [
        "kelinode/core/inbound.go: VLESS tcp network_settings are passed to Xray TCPSettings",
        "kelinode-rs native renderer: native core currently rejects TCP header settings instead of silently dropping them"
      ],
      "panel_node": {
        "protocol": "vless",
        "listen_ip": "127.0.0.1",
        "server_port": 19116,
        "network": "tcp",
        "network_settings": {
          "header": {
            "type": "http"
          }
        }
      },
      "users": [
        {
          "id": 116,
          "uuid": "55555555-5555-5555-5555-555555555555",
          "speed_limit": 0,
          "device_limit": 0
        }
      ],
      "expected": {
        "protocol": "vless",
        "transport_network": "tcp",
        "security": "none",
        "decision": "reject",
        "reject_reason_contains": "does not support transport settings"
      }
