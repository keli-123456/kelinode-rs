  "user_delta": {
    "go_source_reference": [
      "kelinode/node/user_delta.go: applyUserDelta deletes by uuid, upserts by uuid, and sorts next by uuid"
    ],
    "old": [
      {
        "id": 1,
        "uuid": "a",
        "speed_limit": 0,
        "device_limit": 1
      },
      {
        "id": 2,
        "uuid": "b",
        "speed_limit": 0,
        "device_limit": 1
      },
      {
        "id": 3,
        "uuid": "c",
        "speed_limit": 0,
        "device_limit": 1
      }
    ],
    "deleted": [
      {
        "id": 2,
        "uuid": "b",
        "speed_limit": 0,
        "device_limit": 1
      }
    ],
    "upsert": [
      {
        "id": 3,
        "uuid": "c",
        "speed_limit": 10,
        "device_limit": 1
      },
      {
        "id": 4,
        "uuid": "d",
        "speed_limit": 0,
        "device_limit": 2
      }
